    "clinical:workflow:smoke": "vitest run src/clinicalWorkflowReview.test.ts",
    "hwp:smoke:handoff": "bash scripts/export_hwp_smoke_handoff.sh",
    "hwp:smoke:handoff:test": "bash scripts/test_hwp_smoke_handoff.sh",
    "hwp:smoke:test": "bash scripts/test_hwp_sample_smoke.sh",
    "rag:ollama:doctor:test": "bash scripts/test_ollama_runtime_doctor.sh",
