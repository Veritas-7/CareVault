    "objective:readiness:inputs:doctor": "bash scripts/doctor_objective_readiness_inputs.sh",
    "objective:readiness:inputs:doctor:test": "bash scripts/test_objective_readiness_inputs_doctor.sh",
    "objective:readiness:inputs:verify": "bash scripts/verify_objective_readiness_inputs.sh",
    "objective:readiness:inputs:verify:test": "bash scripts/test_objective_readiness_inputs_verify.sh",
