    "rag:safety:smoke": "vitest run src/documentRagContext.test.ts src/documentRagModelRequest.test.ts",
    "rag:model:smoke": "bash scripts/smoke_rag_model.sh",
    "rag:embedding:smoke": "bash scripts/smoke_rag_embedding.sh",
    "rag:ollama:doctor": "bash scripts/doctor_ollama_runtime.sh",
    "rag:ollama:smoke": "bash scripts/smoke_ollama_rag.sh",
