    "runtime:doctor:test": "bash scripts/test_runtime_doctor.sh",
    "desktop:attachment-archive:smoke": "bash scripts/smoke_desktop_attachment_archive_readiness.sh",
    "objective:readiness:smoke": "vitest run src/carevaultObjectiveReadiness.test.ts src/clinicalWorkflowReview.test.ts src/clinicalReviewPacket.test.ts",
    "objective:readiness:export": "bash scripts/export_objective_readiness_report.sh",
    "objective:readiness:export:test": "bash scripts/test_objective_readiness_export.sh",
    "objective:readiness:report": "bash scripts/smoke_objective_readiness_report.sh",
    "objective:readiness:report:test": "bash scripts/test_objective_readiness_report_smoke.sh",
    "objective:readiness:complete": "bash scripts/smoke_objective_readiness_complete.sh",
    "objective:readiness:complete:test": "bash scripts/test_objective_readiness_complete_smoke.sh",
    "objective:readiness:complete:verify": "bash scripts/verify_objective_readiness_complete.sh",
